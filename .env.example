# ===== Gemini (LLM) =====
# Auth is a plain Developer API key (https://aistudio.google.com/apikey) — no service account,
# no ADC. Same key works locally and on Railway; just set it as a secret env var there.
GEMINI_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-3.5-flash

# ===== Algolia (lexical leg) =====
# App ID + a search-only API key is enough for querying.
# An admin/write key is only needed if you also push records to Algolia (not done here).
ALGOLIA_APP_ID=your_app_id
ALGOLIA_API_KEY=your_search_api_key
ALGOLIA_INDEX_NAME=13fcbda9-b656-4559-911f-ce79be7ee6a2

# ===== Postgres + pgvector (semantic leg, on Railway) =====
# Railway exposes this as DATABASE_URL on the Postgres plugin.
DATABASE_URL=postgresql://user:pass@host:5432/railway
PG_TABLE=slides
EMBED_DIM=1024

# ===== Models =====
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Put HF cache on a Railway volume to avoid re-downloading the ~2.3GB models each deploy.
HF_HOME=/models

# ===== Retrieval knobs =====
LEXICAL_TOP_K=50      # candidates pulled from Algolia
SEMANTIC_TOP_K=50     # candidates pulled from pgvector
RRF_K=60              # RRF constant
FUSED_TOP_K=20        # candidates kept after fusion, fed to reranker
RERANK_TOP_N=10        # final passages handed to the LLM
RRF_LEXICAL_WEIGHT=1.0
RRF_SEMANTIC_WEIGHT=1.0
# Pin the reranker's thread count to match the container's actual vCPU limit (e.g. Railway's
# Settings -> Resource Limits). Leave unset for local dev -- os.cpu_count() is accurate there.
# RERANK_NUM_THREADS=8
